@model GuildDetailsViewModel

@{
    ViewData["Title"] = "Guild Details";
}

<div class="page-header">
    <div>
        <h1>Guild Details</h1>
        <p class="page-subtitle">@Model.Guild.GuildName</p>
    </div>
    <div class="form-actions">
        <a asp-action="Edit" asp-route-name="@Model.Guild.GuildName" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-name="@Model.Guild.GuildName" class="btn btn-outline-danger">Delete</a>
    </div>
</div>

<div class="card-panel mb-4">
    <p><strong>Creator:</strong> @Model.Guild.Creator</p>
    <p><strong>Member Count:</strong> @Model.Guild.MemberCount</p>
    <p><strong>Creation Date:</strong> @Model.Guild.CreationDate</p>
</div>

<div class="card-panel mb-4">
    <h3>Benefits</h3>
    @if (Model.Guild.Benefits.Any())
    {
        <ul>
            @foreach (var benefit in Model.Guild.Benefits)
            {
                <li>@benefit</li>
            }
        </ul>
    }
    else
    {
        <p>No benefits listed.</p>
    }
</div>

<div class="card-panel">
    <h3>Members</h3>
    @if (Model.Members.Any())
    {
        <ul>
            @foreach (var member in Model.Members)
            {
                <li>
                    <a asp-controller="Characters" asp-action="Details" asp-route-id="@member.CharacterId">@member.CharacterName</a>
                    - Level @member.CurrentLevel
                </li>
            }
        </ul>
    }
    else
    {
        <p>No guild members found.</p>
    }
</div>

<p class="mt-3">
    <a asp-action="Index">Back to Guilds</a>
</p>
