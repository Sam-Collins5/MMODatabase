@model HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="dashboard-hero">
    <h1>MMOngo Dashboard</h1>
    <p>Welcome to MMOngo. View your players, characters, guilds, and missions from one clean dashboard.</p>
</div>

<div class="dashboard-grid">

    <div class="dashboard-card">
        <h2>Players</h2>

        @if (Model.Players.Any())
        {
            <ul class="dashboard-list">
                @foreach (var player in Model.Players)
                {
                    <li>
                        <a asp-controller="Players" asp-action="Details" asp-route-username="@player.UserName">
                            @player.UserName
                        </a>
                        <span>@player.PlayerName</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="empty-text">No players found.</p>
        }
    </div>

    <div class="dashboard-card">
        <h2>Characters</h2>

        @if (Model.Characters.Any())
        {
            <ul class="dashboard-list">
                @foreach (var character in Model.Characters)
                {
                    <li>
                        <a asp-controller="Characters" asp-action="Details" asp-route-id="@character.CharacterId">
                            @character.CharacterName
                        </a>
                        <span>Level @character.CurrentLevel</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="empty-text">No characters found.</p>
        }
    </div>

    <div class="dashboard-card">
        <h2>Guilds</h2>

        @if (Model.Guilds.Any())
        {
            <ul class="dashboard-list">
                @foreach (var guild in Model.Guilds)
                {
                    <li>
                        <a asp-controller="Guilds" asp-action="Details" asp-route-name="@guild.GuildName">
                            @guild.GuildName
                        </a>
                        <span>Members: @guild.MemberCount</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="empty-text">No guilds found.</p>
        }
    </div>

    <div class="dashboard-card">
        <h2>Missions</h2>

        @if (Model.Missions.Any())
        {
            <ul class="dashboard-list">
                @foreach (var mission in Model.Missions)
                {
                    <li>
                        <a asp-controller="Missions" asp-action="Details" asp-route-name="@mission.MissionName">
                            @mission.MissionName
                        </a>
                        <span>@mission.MissionType</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="empty-text">No missions found.</p>
        }
    </div>

</div>