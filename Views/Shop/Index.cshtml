@model ShopViewModel

@{
    ViewData["Title"] = "Shop";
}

<div class="page-header">
    <div>
        <h1>Shop</h1>
        <p class="page-subtitle">Manage weapons, armor, tools, and spells.</p>
    </div>
</div>

<div class="shop-toolbar">
    <a asp-action="Create" asp-route-category="weapon" class="btn btn-success">Add Weapon</a>
    <a asp-action="Create" asp-route-category="armor" class="btn btn-success">Add Armor</a>
    <a asp-action="Create" asp-route-category="tool" class="btn btn-success">Add Tool</a>
    <a asp-action="Create" asp-route-category="spell" class="btn btn-success">Add Spell</a>
</div>

<h2>Weapons</h2>
<form asp-controller="Shop" asp-action="Index">
    <p>
        <input type="text" name="weaponName" placeholder="Search by weapon name..."/>
        <input type="submit" value="Search"/>
    </p>
</form>
@if (Model.Weapons.Any())
{
    <div class="card-panel mb-4">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Damage</th>
                    <th>Weight</th>
                    <th>Price</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var weapon in Model.Weapons)
                {
                    if (!string.IsNullOrEmpty(Model.WeaponNameSearch))
                    {
                        Console.WriteLine(Model.WeaponNameSearch);
                        if (weapon.WeaponName != Model.WeaponNameSearch)
                        {
                            continue;
                        }
                    }
                    <tr>
                        <td>@weapon.WeaponName</td>
                        <td>@weapon.Damage</td>
                        <td>@weapon.Weight</td>
                        <td>@weapon.Price</td>
                        <td class="table-actions">
                            <a asp-action="Edit" asp-route-category="weapon" asp-route-id="@weapon.WeaponId">Edit</a>
                            <a asp-action="Delete" asp-route-category="weapon" asp-route-id="@weapon.WeaponId">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>No weapons available.</p>
}

