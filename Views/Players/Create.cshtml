@model Player

@{
    ViewData["Title"] = "Create Player";
}

<div class="form-shell">
    <h1>Create Player</h1>

    <form asp-action="Create" method="post" class="entity-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="PlayerName" class="form-label"></label>
            <input asp-for="PlayerName" class="form-control" />
            <span asp-validation-for="PlayerName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Age" class="form-label"></label>
            <input asp-for="Age" class="form-control" />
            <span asp-validation-for="Age" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PasswordHash" class="form-label">Password Hash</label>
            <input asp-for="PasswordHash" class="form-control" />
            <span asp-validation-for="PasswordHash" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MemberSince" class="form-label"></label>
            <input asp-for="MemberSince" class="form-control" placeholder="MM-DD-YYYY" />
            <span asp-validation-for="MemberSince" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-success">Create</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
