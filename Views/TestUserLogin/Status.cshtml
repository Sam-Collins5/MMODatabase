@{
    ViewData["Title"] = "Test Login Status";
}

<h1>Test Login Status</h1>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="alert alert-success">
        You are currently signed in as <strong>@User.Identity.Name</strong>.
    </div>

    <p>
        This confirms that registration, password hashing, login, and cookie authentication are working in the testing setup.
    </p>

    <div class="d-flex gap-2 flex-wrap">
        <form asp-controller="TestUserLogin" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Logout</button>
        </form>

        <form asp-controller="TestUserLogin" asp-action="LogoutAndRegister" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary">Register Another Test Account</button>
        </form>

        <form asp-controller="TestUserLogin" asp-action="LogoutAndLogin" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-secondary">Login As Different Test Account</button>
        </form>
    </div>
}
else
{
    <div class="alert alert-warning">
        You are not signed in.
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="TestUserLogin" asp-action="Login" class="btn btn-primary">
            Go to Test Login
        </a>

        <a asp-controller="TestUserLogin" asp-action="Register" class="btn btn-secondary">
            Go to Test Register
        </a>
    </div>
}